{
  "name": "blast-radius-visualizer",
  "version": "0.1.0",
  "private": true,
  "description": "Blast Radius Pre-Deploy Visualizer - analyzes IaC changesets to identify downstream dependency impact",
  "workspaces": [
    "packages/core",
    "packages/lambdas",
    "packages/frontend",
    "packages/cli",
    "packages/infra"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx,json}'",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx,json}'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "fast-check": "^3.15.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
